# QQ bot connection
QQ_BOT_ADAPTER=onebot
QQ_BOT_HOST=127.0.0.1
QQ_BOT_PORT=3001
QQ_BOT_ACCESS_TOKEN=

# AI provider
AI_PROVIDER=openai_compatible
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
AI_TEMPERATURE=0.7
AI_TIMEOUT_SECONDS=60

# v1.3 Agent runtime / MainAgentGraph.
# ENABLE_MAIN_AGENT opens the QQ /agent entry.
# MAIN_AGENT_USE_LLM lets /agent use the real Main LLM to generate ActionRequest JSON.
# The current live-safe path is still read-only: dev_context only, no shell, no file writes, no DB writes.
ENABLE_MAIN_AGENT=false
MAIN_AGENT_USE_LLM=false
MAIN_AGENT_OWNER_ONLY=true
MAIN_AGENT_ALLOW_GROUP=false
MAIN_AGENT_MAX_STEPS=5
MAIN_AGENT_REQUIRE_APPROVAL_FOR_WRITES=true
ENABLE_AGENT_WEB=false
ENABLE_AGENT_LOCAL_WRITE=false
ENABLE_AGENT_EXTERNAL_WRITE=false
ENABLE_AGENT_SHELL=false

# MainAgent model. Keep MAIN_LLM_API_KEY out of Git.
# MAIN_LLM_BASE_URL should be an OpenAI-compatible API Base URL, for example https://api.example.com/v1.
MAIN_LLM_API_KEY=
MAIN_LLM_BASE_URL=
MAIN_LLM_MODEL=gpt-5.5
MAIN_LLM_TIMEOUT_SECONDS=60

# Vision model: local Ollama is used only to describe images.
ENABLE_VISION=true
VISION_OLLAMA_BASE_URL=http://127.0.0.1:11434
VISION_MODEL=qwen2.5vl:3b
VISION_TIMEOUT_SECONDS=180
VISION_MAX_IMAGES=1
VISION_MAX_IMAGE_BYTES=5242880
VISION_IMAGE_CACHE_TTL_SECONDS=120
VISION_PRIVATE_IMAGE_WAIT_SECONDS=5

# Bot behavior
BOT_NAME=AI助手
BOT_ALIASES=
BOT_OWNER_QQ=
BOT_OWNER_PUBLIC_NAME=
MAX_CONTEXT_MESSAGES=40
ENABLE_MEMORY_COMPRESSION=true
MAX_STORED_MESSAGES_PER_SESSION=120
SUMMARY_KEEP_RECENT_MESSAGES=40
SUMMARY_BATCH_MESSAGES=80
SUMMARY_MIN_SOURCE_MESSAGES=40
MAX_SESSION_SUMMARIES_IN_CONTEXT=3
ENABLE_GAP_SCENE_SUMMARIES=true
GAP_SCENE_SUMMARY_1_THRESHOLD=40
GAP_SCENE_SUMMARY_2_THRESHOLD=80
MAX_GAP_SCENE_SUMMARIES_IN_CONTEXT=2
ENABLE_LONG_TERM_MEMORY_CONTEXT=true
MAX_LONG_TERM_MEMORIES_IN_CONTEXT=8
RULE_REMINDER_INTERVAL_MESSAGES=40

# RAG retrieval (disabled by default for the first rollout)
ENABLE_MEMORY_RAG=false
ENABLE_PROJECT_DOC_RAG=false
MEMORY_RAG_EMBEDDING_PROVIDER=ollama
MEMORY_RAG_EMBEDDING_MODEL=bge-m3
MEMORY_RAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434
MEMORY_RAG_EMBEDDING_DIMENSION=1024
MEMORY_RAG_EMBEDDING_TIMEOUT_SECONDS=60
MEMORY_RAG_TOP_K=5
MEMORY_RAG_MIN_SCORE=0.55
MEMORY_RAG_MAX_CONTEXT_CHARS=1600
PROJECT_DOC_RAG_TOP_K=4
PROJECT_DOC_RAG_MIN_SCORE=0.50
PROJECT_DOC_RAG_MAX_CONTEXT_CHARS=2000
MEMORY_RAG_INCLUDE_MANUAL_FACTS=true
MEMORY_RAG_INCLUDE_MANUAL_PREFERENCES=true
MEMORY_RAG_INCLUDE_SESSION_SUMMARIES=true
MEMORY_RAG_INCLUDE_SHORT_MESSAGES=false
MEMORY_RAG_INCLUDE_GAP_SCENE_SUMMARIES=false
MEMORY_RAG_OWNER_ONLY_DEBUG=true
MEMORY_RAG_INJECT_IN_CHAT=false

ENABLE_GROUP_CHAT=true
ENABLE_PRIVATE_CHAT=true

# Access control
PRIVATE_WHITELIST=
ALLOW_UNKNOWN_PRIVATE_CHAT=false
PRIVATE_TRIAL_MESSAGES=3
PRIVATE_RATE_LIMIT_SECONDS=10
MAX_PRIVATE_MESSAGE_LENGTH=150

GROUP_WHITELIST=
GROUP_RATE_LIMIT_SECONDS=5
MAX_GROUP_MESSAGE_LENGTH=300
ENABLE_GROUP_AUTO_REPLY=false
GROUP_AUTO_REPLY_THRESHOLD=50
GROUP_AUTO_REPLY_COOLDOWN_SECONDS=60
GROUP_AUTO_REPLY_OWNER_COOLDOWN_SECONDS=30
GROUP_AUTO_REPLY_USER_COOLDOWN_SECONDS=120
ENABLE_OWNER_NOTIFICATIONS=true
OWNER_NOTIFICATION_MAX_LENGTH=50
OWNER_NOTIFICATION_GLOBAL_COOLDOWN_SECONDS=60
OWNER_NOTIFICATION_GROUP_COOLDOWN_SECONDS=120
OWNER_NOTIFICATION_USER_COOLDOWN_SECONDS=300

USER_BLACKLIST=

# Voice output / local TTS
ENABLE_TTS=false
TTS_SERVICE_URL=http://127.0.0.1:7861
TTS_VOICE=zh_kelin_raw_20260625_222137
TTS_EMOTION=affection
TTS_TIMEOUT_SECONDS=180
TTS_MAX_CHARS=180
TTS_MAX_TOTAL_SECONDS=60
TTS_COOLDOWN_SECONDS=20
TTS_AUTO_START=true
TTS_STARTUP_WAIT_SECONDS=45

# Storage
DATA_DIR=./data
LOG_DIR=./logs
