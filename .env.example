# NoneBot server
HOST=127.0.0.1
PORT=8080
DRIVER=~fastapi+~httpx+~websockets

# OneBot v11
ONEBOT_ACCESS_TOKEN=

# AI model: DeepSeek uses an OpenAI-compatible API.
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
AI_TEMPERATURE=0.7
AI_TIMEOUT_SECONDS=60

# v1.3 Agent runtime / MainAgentGraph.
# ENABLE_MAIN_AGENT opens the QQ /agent entry.
# MAIN_AGENT_USE_LLM lets /agent use the real Main LLM to generate ActionRequest JSON.
# Formal work reports are read-local: development context and deterministic system overview.
# Registered owner writes still require approval; no shell, arbitrary file write, or unregistered DB write is exposed.
ENABLE_MAIN_AGENT=false
MAIN_AGENT_USE_LLM=false
MAIN_AGENT_OWNER_ONLY=true
MAIN_AGENT_ALLOW_GROUP=false
MAIN_AGENT_MAX_STEPS=5
MAIN_AGENT_REQUIRE_APPROVAL_FOR_WRITES=true
ENABLE_AGENT_WEB=false
# Reserved fixed provider configuration. A Key alone does not enable networking;
# production wiring remains absent until the external-read rollout is approved.
TAVILY_API_KEY=
TAVILY_TIMEOUT_SECONDS=10
ENABLE_AGENT_LOCAL_WRITE=false
ENABLE_AGENT_EXTERNAL_WRITE=false
ENABLE_AGENT_SHELL=false

# Optional local Web Owner Console static page serving.
# Keep disabled by default; when true, build web/owner-console first.
OWNER_CONSOLE_STATIC_ENABLED=false
OWNER_CONSOLE_STATIC_DIR=web/owner-console/dist

# MainAgent model. Keep MAIN_LLM_API_KEY out of Git.
# MAIN_LLM_BASE_URL should be an OpenAI-compatible API Base URL, for example https://api.example.com/v1.
MAIN_LLM_API_KEY=
MAIN_LLM_BASE_URL=
MAIN_LLM_MODEL=gpt-5.5
MAIN_LLM_TIMEOUT_SECONDS=60

CHAT_LLM_API_KEY=your_deepseek_api_key
CHAT_LLM_BASE_URL=https://api.deepseek.com
CHAT_LLM_MODEL=deepseek-v4-flash
CHAT_LLM_TIMEOUT_SECONDS=60

# Vision model: local Ollama is used only to describe images.
ENABLE_VISION=true
VISION_OLLAMA_BASE_URL=http://127.0.0.1:11434
VISION_MODEL=qwen2.5vl:3b
VISION_TIMEOUT_SECONDS=180
VISION_NUM_CTX=16384
VISION_MAX_IMAGES=1
VISION_MAX_IMAGE_BYTES=5242880
VISION_IMAGE_CACHE_TTL_SECONDS=120
VISION_PRIVATE_IMAGE_WAIT_SECONDS=5

# Local sticker inspection, owner approval, and owner-private explicit preview.
# Preview sends at most one approved+enabled local asset per strict command.
# It does not enable normal-chat attachments or any automatic sending.
ENABLE_LOCAL_STICKERS=false
LOCAL_STICKER_MAX_FILE_BYTES=2097152
LOCAL_STICKER_MAX_DYNAMIC_FILE_BYTES=5242880
LOCAL_STICKER_MIN_DIMENSION=32
LOCAL_STICKER_MAX_DIMENSION=2048
LOCAL_STICKER_MAX_PIXELS=4194304
LOCAL_STICKER_MAX_ANIMATION_FRAMES=120
LOCAL_STICKER_MAX_ANIMATION_DURATION_MS=10000
LOCAL_STICKER_MIN_FRAME_DURATION_MS=20
LOCAL_STICKER_MAX_ANIMATION_DECODED_PIXELS=60000000
LOCAL_STICKER_PREVIEW_COOLDOWN_SECONDS=3

# B1 shadow intent only. Shadow parses a finite ChatAgent suggestion and runs
# local selection gates, but never sends a sticker. Automatic attachments stay
# separately disabled until a later owner-approved B2 live rollout.
ENABLE_CHAT_STICKER_INTENT_SHADOW=false
ENABLE_CHAT_STICKER_ATTACHMENTS=false

# Decoupled remote sticker classifier. It uses a separate API key and runs only
# after a complete owner-private text reply was sent. It never falls back to the
# ChatAgent key, never changes the reply, and remains shadow-only here.
ENABLE_REMOTE_STICKER_CLASSIFIER=false
STICKER_CLASSIFIER_BASE_URL=https://api.deepseek.com
STICKER_CLASSIFIER_API_KEY=
STICKER_CLASSIFIER_MODEL=deepseek-v4-flash
STICKER_CLASSIFIER_TIMEOUT_SECONDS=8
STICKER_CLASSIFIER_MAX_INPUT_CHARS=2400
CHAT_STICKER_OWNER_PRIVATE_ONLY=true
CHAT_STICKER_COOLDOWN_SECONDS=120
CHAT_STICKER_MIN_MESSAGES_BETWEEN=4
CHAT_STICKER_MAX_PER_HOUR=6
CHAT_STICKER_MAX_PER_REPLY=1
CHAT_STICKER_MIN_INTENT_CONFIDENCE=0.82

# Bot behavior
BOT_NAME=AI助手
BOT_ALIASES=
BOT_OWNER_QQ=
BOT_OWNER_PUBLIC_NAME=
BOT_TIMEZONE=Asia/Shanghai
ENABLE_PRIVATE_CHAT=true
ENABLE_GROUP_CHAT=true
MAX_CONTEXT_MESSAGES=40
ENABLE_MEMORY_COMPRESSION=true
MAX_STORED_MESSAGES_PER_SESSION=120
SUMMARY_KEEP_RECENT_MESSAGES=40
SUMMARY_BATCH_MESSAGES=80
SUMMARY_MIN_SOURCE_MESSAGES=40
MAX_SESSION_SUMMARIES_IN_CONTEXT=3
ENABLE_GAP_SCENE_SUMMARIES=true
GAP_SCENE_SUMMARY_1_THRESHOLD=40
GAP_SCENE_SUMMARY_2_THRESHOLD=80
MAX_GAP_SCENE_SUMMARIES_IN_CONTEXT=2
ENABLE_LONG_TERM_MEMORY_CONTEXT=true
MAX_LONG_TERM_MEMORIES_IN_CONTEXT=8
RULE_REMINDER_INTERVAL_MESSAGES=40

# Access control
PRIVATE_WHITELIST=
ALLOW_UNKNOWN_PRIVATE_CHAT=false
PRIVATE_TRIAL_MESSAGES=3
PRIVATE_RATE_LIMIT_SECONDS=10
MAX_PRIVATE_MESSAGE_LENGTH=150

GROUP_WHITELIST=
GROUP_RATE_LIMIT_SECONDS=5
MAX_GROUP_MESSAGE_LENGTH=300
ENABLE_GROUP_AUTO_REPLY=false
GROUP_AUTO_REPLY_THRESHOLD=50
GROUP_AUTO_REPLY_COOLDOWN_SECONDS=60
GROUP_AUTO_REPLY_OWNER_COOLDOWN_SECONDS=30
GROUP_AUTO_REPLY_USER_COOLDOWN_SECONDS=120
ENABLE_OWNER_NOTIFICATIONS=true
OWNER_NOTIFICATION_MAX_LENGTH=50
OWNER_NOTIFICATION_GLOBAL_COOLDOWN_SECONDS=60
OWNER_NOTIFICATION_GROUP_COOLDOWN_SECONDS=120
OWNER_NOTIFICATION_USER_COOLDOWN_SECONDS=300

USER_BLACKLIST=

# Voice output / local TTS
ENABLE_TTS=false
TTS_SERVICE_URL=http://127.0.0.1:7861
TTS_VOICE=zh_kelin_raw_20260625_222137
TTS_EMOTION=affection
TTS_TIMEOUT_SECONDS=180
TTS_MAX_CHARS=180
TTS_MAX_TOTAL_SECONDS=60
TTS_COOLDOWN_SECONDS=20
TTS_AUTO_START=true
TTS_STARTUP_WAIT_SECONDS=45

# NapCatQQ
# Optional: set one QQ number to skip multi-account selection.
NAPCAT_QQ=
